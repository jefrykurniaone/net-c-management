# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Dapatkan dari: Supabase Dashboard → Settings → Database → Connection string
# Gunakan "Transaction" mode (port 6543) untuk DATABASE_URL (dipakai Prisma Client runtime)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Gunakan "Session" mode (port 5432) untuk DIRECT_URL (dipakai prisma db push / migrate)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate dengan: openssl rand -base64 32 atau https://generate-secret.vercel.app/32
AUTH_SECRET="your-nextauth-secret-here"
# URL aplikasi kamu (ganti sesuai domain production)
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ────────────────────────────────────────────────────────────
# CARA SETUP GOOGLE OAUTH:
# 1. Buka https://console.cloud.google.com/
# 2. Buat project baru atau pilih project yang ada
# 3. Masuk ke "APIs & Services" → "Credentials"
# 4. Klik "Create Credentials" → "OAuth 2.0 Client IDs"
# 5. Application type: "Web application"
# 6. Tambahkan Authorized JavaScript origins:
#    - http://localhost:3000 (development)
#    - https://your-domain.com (production)
# 7. Tambahkan Authorized redirect URIs:
#    - http://localhost:3000/api/auth/callback/google (development)
#    - https://your-domain.com/api/auth/callback/google (production)
# 8. Klik Create, copy Client ID dan Client Secret di bawah
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ─── Supabase Storage ─────────────────────────────────────────────────────────
# Dapatkan dari: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
# Service Role Key (JANGAN expose ke client, hanya untuk server-side)
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
